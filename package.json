{
  "name": "pro-sms-backend-service",
  "version": "0.0.1",
  "license": "SEE LICENSE IN LICENSE.txt",
  "main": "index.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "check-node-version": "node -e \"if (!/^v22\\./.test(process.version)) { console.error('You must run the project with Node v22, thank you!'); process.exit(1); }\"",
    "copy-templates": "shx cp -r src/templates dist/src",
    "preinstall": "npm run check-node-version",
    "prestart": "npm run check-node-version",
    "start": "tsc && node --trace-deprecation dist/src/index.js",
    "prebuild": "npm run check-node-version",
    "build": "tsc --build",
    "postbuild": "npm run copy-templates",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint",
    "lint:fix": "eslint src/**/*.ts --ext .ts --fix",
    "lint-staged": "lint-staged",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.36.0",
    "@types/adm-zip": "^0.5.7",
    "@types/archiver": "^7.0.0",
    "@types/config": "^3.3.5",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.5",
    "@types/fs-extra": "^11.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.2",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "nodemon": "^3.1.10",
    "patch-package": "^8.0.1",
    "pinst": "^3.0.0",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.6.2",
    "shx": "^0.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.922.0",
    "@typegoose/typegoose": "^12.19.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "argon2": "^0.44.0",
    "axios": "^1.13.2",
    "better-auth": "^1.4.1",
    "config": "^4.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "docxtemplater": "^3.67.5",
    "docxtemplater-image-module-free": "^1.1.1",
    "dotenv": "^17.2.2",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "fs-extra": "^11.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.1",
    "mongoose": "^8.19.2",
    "multer": "2.0.2",
    "nodemailer": "^7.0.9",
    "officegen": "^0.6.5",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.2.0",
    "qrcode": "^1.5.4",
    "resend": "^6.12.4",
    "sqids": "^0.3.0",
    "uuid": "^13.0.0",
    "winston": "^3.17.0",
    "zod": "^4.1.11"
  },
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.{js,css,md}": "prettier --write"
  },
  "packageManager": "yarn@1.22.22"
}
