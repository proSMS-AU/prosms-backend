<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New SSID Request</title>
  </head>
  <body style="margin:0;padding:0;background-color:#f4f4f5;font-family:sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0" style="padding:40px 0;">
      <tr>
        <td align="center">
          <table width="100%" style="max-width:520px;background:#ffffff;border-radius:12px;padding:40px;border:1px solid #e4e4e7;">
            <tr>
              <td>
                <h2 style="margin:0 0 8px;font-size:20px;color:#18181b;">New SSID Request</h2>
                <p style="margin:0 0 24px;font-size:14px;color:#71717a;">
                  An organisation has requested an SSID through ProSMS.
                </p>

                <table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f5;border-radius:8px;padding:16px;margin-bottom:24px;">
                  <tr><td style="font-size:13px;color:#71717a;padding:4px 0;">Organisation</td><td style="font-size:13px;font-weight:600;color:#18181b;text-align:right;padding:4px 0;"><%= organizationName %></td></tr>
                  <tr><td style="font-size:13px;color:#71717a;padding:4px 0;">RTO ID</td><td style="font-size:13px;font-weight:600;color:#18181b;text-align:right;padding:4px 0;"><%= rtoId %></td></tr>
                  <tr><td style="font-size:13px;color:#71717a;padding:4px 0;">ABN</td><td style="font-size:13px;font-weight:600;color:#18181b;text-align:right;padding:4px 0;"><%= abn %></td></tr>
                  <tr><td style="font-size:13px;color:#71717a;padding:4px 0;">Requested At</td><td style="font-size:13px;font-weight:600;color:#18181b;text-align:right;padding:4px 0;"><%= requestDate %></td></tr>
                </table>

                <p style="margin:0 0 16px;font-size:14px;color:#3f3f46;">
                  Log in to the ProSMS Super Admin dashboard to review and generate the SSID for this organisation.
                </p>

                <div style="text-align:center;margin:24px 0;">
                  <a href="<%= dashboardUrl %>" style="display:inline-block;background:#18181b;color:#ffffff;font-size:14px;font-weight:600;padding:12px 28px;border-radius:8px;text-decoration:none;">
                    Go to SSID Requests
                  </a>
                </div>

                <p style="margin:0;font-size:12px;color:#a1a1aa;text-align:center;">
                  ProSMS Super Admin · This is an automated notification.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
