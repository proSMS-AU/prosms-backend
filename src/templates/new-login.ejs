<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Sign-In Detected</title>
  </head>
  <body style="margin:0;padding:0;background-color:#f4f4f5;font-family:sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0" style="padding:40px 0;">
      <tr>
        <td align="center">
          <table width="100%" style="max-width:480px;background:#ffffff;border-radius:12px;padding:40px;border:1px solid #e4e4e7;">
            <tr>
              <td>
                <!-- Header -->
                <div style="margin-bottom:24px;">
                  <div style="display:inline-block;background:#dcfce7;border-radius:50%;width:44px;height:44px;text-align:center;line-height:44px;font-size:22px;margin-bottom:12px;">🔐</div>
                  <h2 style="margin:0 0 6px;font-size:20px;color:#18181b;">New sign-in to your account</h2>
                  <p style="margin:0;font-size:14px;color:#71717a;">Hi <%= name %>, a new sign-in was detected on your ProSMS account.</p>
                </div>

                <!-- Device info box -->
                <table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f5;border-radius:8px;padding:16px;margin-bottom:24px;">
                  <tr>
                    <td>
                      <table width="100%" cellpadding="0" cellspacing="0">
                        <tr>
                          <td style="font-size:12px;color:#71717a;padding-bottom:6px;">DEVICE</td>
                          <td style="font-size:12px;color:#71717a;padding-bottom:6px;">TIME</td>
                        </tr>
                        <tr>
                          <td style="font-size:14px;color:#18181b;font-weight:600;"><%= device %></td>
                          <td style="font-size:14px;color:#18181b;font-weight:600;"><%= time %></td>
                        </tr>
                        <% if (ipAddress) { %>
                        <tr>
                          <td colspan="2" style="font-size:12px;color:#71717a;padding-top:6px;">IP: <%= ipAddress %></td>
                        </tr>
                        <% } %>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- Warning -->
                <div style="background:#fef9c3;border:1px solid #fde047;border-radius:8px;padding:14px 16px;margin-bottom:24px;">
                  <p style="margin:0;font-size:13px;color:#713f12;">
                    <strong>Wasn't you?</strong> If you didn't sign in, your account may be compromised. Review your active sessions and change your password immediately.
                  </p>
                </div>

                <p style="margin:0;font-size:12px;color:#a1a1aa;text-align:center;">
                  If this was you, no action is needed. You can safely ignore this email.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
